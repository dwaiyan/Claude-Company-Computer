{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "identity-users": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "content": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/tech-trees/{**catch-all}"
        }
      },
      "learning": {
        "ClusterId": "learning-cluster",
        "Match": {
          "Path": "/api/learning/{**catch-all}"
        }
      },
      "collaboration": {
        "ClusterId": "collaboration-cluster",
        "Match": {
          "Path": "/api/notes/{**catch-all}"
        }
      },
      "discussions": {
        "ClusterId": "collaboration-cluster",
        "Match": {
          "Path": "/api/discussions/{**catch-all}"
        }
      },
      "contributions": {
        "ClusterId": "collaboration-cluster",
        "Match": {
          "Path": "/api/contributions/{**catch-all}"
        }
      },
      "notifications": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": { "Address": "http://localhost:5001/" }
        }
      },
      "content-cluster": {
        "Destinations": {
          "content-destination": { "Address": "http://localhost:5002/" }
        }
      },
      "learning-cluster": {
        "Destinations": {
          "learning-destination": { "Address": "http://localhost:5003/" }
        }
      },
      "collaboration-cluster": {
        "Destinations": {
          "collaboration-destination": { "Address": "http://localhost:5004/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": { "Address": "http://localhost:5005/" }
        }
      }
    }
  }
}
